---
import ThemeToggle from '@/components/ThemeToggle.astro';
import LanguageToggle from '@/components/LanguageToggle.astro';
import MenuIcon from '@/assets/Menu.astro';

interface Props {
  t: any;
  lang: string;
}

interface NavLink {
  label: string;
  href: string;
}

const { t, lang } = Astro.props;

const navLinks: NavLink[] = [
  { label: t.header.nav.experience, href: '/#experience' },
  { label: t.header.nav.projects, href: '/#projects' },
  { label: t.header.nav.certifications, href: `/${lang}/certifications` },
  { label: t.header.nav.about, href: '/#about' },
  { label: t.header.nav.contact, href: 'mailto:ldelvillarvazquez@gmail.com' },
];
---

<header
  class="sticky top-0 z-40 w-full text-gray-700 backdrop-blur-xl dark:text-white"
>
  <div
    class="container mx-auto flex items-center justify-between p-4 lg:justify-evenly"
  >
    <a
      href={lang === 'es' ? '/es' : '/en'}
      class="text-lg font-bold text-black dark:text-white"
    >
      {t.header.name}
    </a>

    <nav class="hidden space-x-8 lg:flex">
      {
        navLinks.map(link => (
          <a
            href={link.href}
            class="hover:text-yellow-600 dark:hover:text-yellow-400"
          >
            {link.label}
          </a>
        ))
      }
    </nav>

    <div class="flex items-center gap-2">
      <button id="menu-toggle" class="focus:outline-none lg:hidden">
        <MenuIcon />
      </button>
      <ThemeToggle />
      <LanguageToggle currentLang={lang} />
    </div>
  </div>

  <!-- Mobile menu -->
  <nav id="mobile-menu" class="hidden h-screen backdrop-blur-lg lg:hidden">
    <ul class="space-y-4 p-4">
      {
        navLinks.map(link => (
          <li>
            <a href={link.href} class="block hover:text-gray-900">
              {link.label}
            </a>
          </li>
        ))
      }
    </ul>
  </nav>
</header>

<script>
  // Toggle mobile menu
  document.getElementById('menu-toggle')?.addEventListener('click', () => {
    const mobileMenu = document.getElementById('mobile-menu');
    mobileMenu?.classList.toggle('hidden');
    mobileMenu?.classList.toggle('block');
  });

  // Highlight current section
  function highlightCurrentSection() {
    const sections = ['experience', 'projects', 'certifications', 'about'];

    // Remove highlight from all nav links
    document.querySelectorAll('nav a').forEach(link => {
      link.classList.remove('text-primary', 'dark:text-primary', 'font-bold');
    });

    // Highlight certifications link when on the certifications page
    const onCertifications = window.location.pathname.endsWith('/certifications');
    if (onCertifications) {
      document.querySelectorAll('nav a[href$="/certifications"]').forEach(link => {
        link.classList.add('text-primary', 'dark:text-primary', 'font-bold');
      });
      return;
    }

    // Find which section is currently in view
    let currentSection = null;
    for (const section of sections) {
      const element = document.getElementById(section);
      if (element) {
        const rect = element.getBoundingClientRect();
        if (rect.top <= 250) {
          currentSection = section;
        }
      }
    }

    // Highlight the corresponding nav link
    if (currentSection) {
      const selector =
        currentSection === 'certifications'
          ? 'nav a[href$="/certifications"]'
          : `a[href="/#${currentSection}"]`;
      document.querySelectorAll(selector).forEach(link => {
        link.classList.add('text-primary', 'dark:text-primary', 'font-bold');
      });
    }
  }

  // Call on load and scroll
  window.addEventListener('load', highlightCurrentSection);
  window.addEventListener('scroll', highlightCurrentSection);
</script>
