---
import List from '@/assets/List.astro';
import AstroIcon from '@/assets/logos/AstroIcon.astro';
import ReactIcon from '@/assets/logos/ReactIcon.astro';
import Vue from '@/assets/logos/Vue.astro';
import NextJS from '@/assets/logos/NextJS.astro';
import Tailwind from '@/assets/logos/Tailwind.astro';
import Figma from '@/assets/logos/Figma.astro';
import Node from '@/assets/logos/Node.astro';
import Python from '@/assets/logos/Python.astro';
import Express from '@/assets/logos/Express.astro';
import FastAPI from '@/assets/logos/Fastapi.astro';
import MySQL from '@/assets/logos/MySQL.astro';
import MongoDB from '@/assets/logos/MongoDB.astro';
import GCP from '@/assets/logos/GCP.astro';
import Azure from '@/assets/logos/Azure.astro';
import Docker from '@/assets/logos/Docker.astro';
import Kubernetes from '@/assets/logos/Kubernetes.astro';
import Linux from '@/assets/logos/Linux.astro';
import C from '@/assets/logos/C.astro';
import N8n from '@/assets/logos/N8n.astro';
import Make from '@/assets/logos/Make.astro';
import Langgraph from '@/assets/logos/Langgraph.astro';
import MCP from '@/assets/logos/MCP.astro';

// @ts-ignore
import 'atropos/css';

interface TechField {
  name: string;
  technologies: {
    icon: typeof AstroIcon;
    name: string;
  }[];
}

const { t } = Astro.props;

const FIELDS: TechField[] = [
  {
    name: 'Frontend',
    technologies: [
      {
        icon: AstroIcon,
        name: 'Astro',
      },
      {
        icon: ReactIcon,
        name: 'React',
      },
      {
        icon: NextJS,
        name: 'Next.js',
      },
      {
        icon: Vue,
        name: 'Vue.js',
      },
      {
        icon: Tailwind,
        name: 'Tailwind CSS',
      },
      {
        icon: Figma,
        name: 'Figma',
      },
    ],
  },
  {
    name: 'Backend',
    technologies: [
      {
        icon: Node,
        name: 'Node.js',
      },
      {
        icon: Python,
        name: 'Python',
      },
      {
        icon: Express,
        name: 'Express',
      },
      {
        icon: FastAPI,
        name: 'FastAPI',
      },
      {
        icon: MySQL,
        name: 'MySQL',
      },
      {
        icon: MongoDB,
        name: 'MongoDB',
      },
    ],
  },
  {
    name: t.techstack.cloud,
    technologies: [
      {
        icon: GCP,
        name: 'GCP',
      },
      {
        icon: Azure,
        name: 'Azure',
      },
      {
        icon: Docker,
        name: 'Docker',
      },
      {
        icon: Kubernetes,
        name: 'Kubernetes',
      },
      {
        icon: Linux,
        name: 'Linux',
      },
      {
        icon: C,
        name: 'C',
      },
    ],
  },
  {
    name: t.techstack.ai,
    technologies: [
      {
        icon: Langgraph,
        name: 'LangGraph',
      },
      {
        icon: MCP,
        name: 'MCP',
      },
      {
        icon: N8n,
        name: 'n8n',
      },
      {
        icon: Make,
        name: 'Make',
      },
    ],
  },
];
---

<section id="techstack" class="mx-auto max-w-5xl scroll-m-20 py-16 sm:px-4">
  <h2
    class="mb-6 flex items-center text-3xl font-bold text-gray-900 dark:text-white"
  >
    <span class="mr-5">
      <List />
    </span>
    Tech Stack
  </h2>

  <div class="flex flex-col gap-5 md:grid md:grid-cols-2">
    {
      FIELDS.map(field => (
        <div class="atropos my-atropos">
          <div class="atropos-scale">
            <div class="atropos-rotate">
              <div class="atropos-inner">
                <div class="flex h-full flex-col items-center rounded-2xl border border-gray-200 bg-white dark:border-gray-800 dark:bg-transparent">
                  <h2 class="mt-3 bg-linear-to-t from-[#fffc5f] to-[#c9b500] bg-clip-text text-3xl font-bold text-transparent dark:from-[#fffec9] dark:to-[#efeb00]">
                    {field.name}
                  </h2>
                  <div class="my-6 grid grid-cols-3 gap-6">
                    {field.technologies.map(technology => (
                      <div class="flex flex-col items-center justify-center text-gray-800 dark:text-gray-200">
                        <div class="text-black dark:text-white">
                          <technology.icon class="size-13" />
                        </div>
                        <h3>{technology.name}</h3>
                      </div>
                    ))}
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>
      ))
    }
  </div>
</section>

<script>
  import Atropos from 'atropos';

  // Initialize
  document.querySelectorAll('.my-atropos').forEach(el => {
    Atropos({ el: el as HTMLElement });
  });
</script>
