---
import ProjectCard from '@/components/ProjectCard.astro';
import Code from '@/assets/Code.astro';
import RightArrow from '@/assets/RightArrow.astro';
import { PROJECTS, TECH_META, FALLBACK_BG } from '@/data/projects';
import type { Lang } from '@/i18n/config';

const { t } = Astro.props;
const lang = (Astro.params?.lang ?? 'es') as Lang;
---

<section id="projects" class="mx-auto max-w-5xl scroll-m-20 py-16 sm:px-4">
  <h2
    class="mb-6 flex items-center text-3xl font-bold text-gray-900 dark:text-white"
  >
    <span class="mr-5">
      <Code />
    </span>
    {t.projects.title}
  </h2>
  <div class="mt-5 flex flex-col gap-16">
    {
      PROJECTS.map(project => (
        <ProjectCard
          image={project.image}
          title={t.projects[project.id].title}
          description={t.projects[project.id].description}
          github={project.github ?? ''}
          preview={project.preview}
          technologies={project.stack.map(name => ({
            icon: TECH_META[name]?.icon,
            name,
            bgcolor: TECH_META[name]?.bgcolor ?? FALLBACK_BG,
          }))}
        />
      ))
    }
  </div>
  <div class="mt-8 flex justify-center">
    <a
      href={`/${lang}/projects`}
      class="inline-flex items-center gap-2 rounded-lg border border-gray-200 bg-white px-5 py-2.5 text-sm font-medium text-yellow-500 hover:bg-gray-50 hover:text-yellow-400 dark:border-gray-700 dark:bg-gray-800 dark:text-yellow-400 dark:hover:bg-gray-700"
    >
      {t.projects.view_all}
      <RightArrow />
    </a>
  </div>
</section>
