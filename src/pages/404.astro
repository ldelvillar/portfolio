---
import { getTranslations } from '@/utils/getTranslations';
import type { Lang } from '@/i18n/config';
import Layout from '@/layouts/Layout.astro';

const lang = (Astro.url.pathname.startsWith('/en') ? 'en' : 'es') as Lang;
const t = await getTranslations(lang);

const title = `${t.not_found.title} - Lucas del Villar`;
---

<Layout title={title} lang={lang}>
  <section>
    <div
      class="max-w-7-xl mx-auto flex min-h-[80vh] items-center justify-center px-4 lg:px-6"
    >
      <div class="mx-auto max-w-screen-sm text-center">
        <h1
          class="mb-4 text-7xl font-extrabold tracking-tight text-yellow-500 lg:text-9xl dark:text-yellow-400"
        >
          404
        </h1>
        <p
          class="mb-4 text-3xl font-bold tracking-tight text-gray-900 md:text-4xl dark:text-white"
        >
          {t.not_found.title}
        </p>
        <p class="mb-4 text-lg font-light text-gray-500 dark:text-gray-400">
          {t.not_found.description}
        </p>
        <a
          href={`/${lang}`}
          class="my-4 inline-flex rounded-lg bg-yellow-600 px-5 py-2.5 text-center text-sm font-medium text-white hover:bg-yellow-800 focus:ring-4 focus:ring-yellow-300 focus:outline-none dark:focus:ring-yellow-900"
          >{t.not_found.back_to_home}</a
        >
      </div>
    </div>
  </section>
</Layout>
